# Serve the Next.js static export from /out as the site root.
# Hostinger deploys the full repo into public_html; this rewrites
# all requests so visitors see the built site, not the source code.

RewriteEngine On

# If the request already starts with /out/, leave it alone.
RewriteCond %{REQUEST_URI} ^/out/ [OR]
# Don't rewrite the .htaccess itself.
RewriteCond %{REQUEST_URI} ^/\.htaccess$
RewriteRule ^ - [L]

# Map the bare root "/" to /out/index.html
RewriteRule ^$ out/index.html [L]

# For any other request, prepend /out/ and serve from there.
RewriteCond %{DOCUMENT_ROOT}/out%{REQUEST_URI} -f [OR]
RewriteCond %{DOCUMENT_ROOT}/out%{REQUEST_URI} -d
RewriteRule ^(.*)$ out/$1 [L]

# If the file/dir doesn't exist under /out either, try Next.js-style
# clean URLs by appending .html (e.g. /about -> /out/about.html)
RewriteCond %{DOCUMENT_ROOT}/out/$1.html -f
RewriteRule ^(.*)$ out/$1.html [L]

# Fallback: serve the 404 page from the export.
ErrorDocument 404 /out/404.html
